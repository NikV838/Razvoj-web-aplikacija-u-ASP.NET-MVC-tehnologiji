@model SljemeTimeAttack.ViewModels.CarDeleteViewModel

@{
    ViewData["Title"] = $"Delete {Model.Name}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/car-pages.css" asp-append-version="true" />
}

<section class="car-index-page">
    <div class="car-list-section car-delete-shell">
        <article class="car-form-card car-delete-card">
            <p class="car-kicker">@Model.RegistrationNumber</p>
            <h1 class="car-list-title">Delete @Model.Name?</h1>
            <p class="car-delete-copy">This removes the car from the garage. Driver: @(Model.DriverName ?? "Unassigned").</p>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="car-action-row">
                <button type="submit" class="car-action car-action-danger">Delete car</button>
                <a class="car-action car-action-secondary" asp-controller="Car" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
            </form>
        </article>
    </div>
</section>
