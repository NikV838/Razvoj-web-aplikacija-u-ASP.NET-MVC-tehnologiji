@model SljemeTimeAttack.ViewModels.CarCreateViewModel

@{
    ViewData["Title"] = "Create Car";
}

@section Styles {
    <link rel="stylesheet" href="~/css/driver-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/car-pages.css" asp-append-version="true" />
}

<section class="car-index-page">
    <div class="car-list-section car-form-shell">
        <div class="car-page-header">
            <div>
                <p class="car-kicker">Garage control</p>
                <h1 class="car-list-title">Create car</h1>
            </div>
            <a class="car-action car-action-secondary" asp-controller="Car" asp-action="Index">Back to cars</a>
        </div>

        <form asp-action="Create" method="post" enctype="multipart/form-data" class="car-form-card driver-form-card" data-driver-form novalidate>
            @await Html.PartialAsync("_CarForm", Model)

            <div class="driver-form-actions">
                <button type="submit" class="car-action car-action-primary">Create car</button>
                <a class="car-action car-action-secondary" asp-controller="Car" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</section>

<script src="~/js/timeattack-autocomplete.js" asp-append-version="true"></script>
<script src="~/js/timeattack-inline-parts.js" asp-append-version="true"></script>
<script src="~/js/car-image-upload.js" asp-append-version="true"></script>
@await Html.PartialAsync("~/Views/Driver/_DriverClientValidation.cshtml")
