@model SljemeTimeAttack.Models.Car

@{
    ViewData["Title"] = $"{Model.Make} {Model.Model}";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var canManage = User.IsInRole("Admin") || (isAuthenticated && Model.Driver?.AppUserId == currentUserId);
    var backgroundClass = Model.Id switch
    {
        1 => "car-bg-rx8",
        2 => "car-bg-celica",
        3 => "car-bg-mr2",
        4 => "car-bg-eg6",
        5 => "car-bg-s2k",
        _ => "car-bg-garage"
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/car-pages.css" asp-append-version="true" />
}

<section class="car-details-page @backgroundClass">
    <div class="car-details-card">
        <div class="car-details-header">
            <h1 class="car-details-title">@Model.Make @Model.Model</h1>
            @if (canManage)
            {
                <div class="car-action-row">
                    <a class="car-action car-action-secondary" asp-controller="Car" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
                    <a class="car-action car-action-danger" asp-controller="Car" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
                </div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
        {
            <a class="car-details-image" href="@Model.ImagePath" target="_blank" rel="noopener">
                <img src="@Model.ImagePath" alt="@Model.Make @Model.Model" />
            </a>
        }

        <table class="car-details-table">
            <tbody>
                <tr>
                    <th>Registration</th>
                    <td>@Model.RegistrationNumber</td>
                </tr>
                <tr>
                    <th>Year</th>
                    <td>@Model.Year</td>
                </tr>
                <tr>
                    <th>Horsepower</th>
                    <td>@Model.Horsepower hp</td>
                </tr>
                <tr>
                    <th>Weight</th>
                    <td>@Model.WeightKg kg</td>
                </tr>
                <tr>
                    <th>Driver</th>
                    <td>@(Model.Driver?.Name ?? "Unassigned")</td>
                </tr>
                <tr>
                    <th>Tire</th>
                    <td>@Model.WheelSetup.Brand @Model.WheelSetup.Model (@Model.WheelSetup.Type)</td>
                </tr>
                <tr>
                    <th>Tire DOT</th>
                    <td>@Model.WheelSetup.Dot</td>
                </tr>
                <tr>
                    <th>Rim</th>
                    <td>@Model.WheelSetup.Rim.Make @Model.WheelSetup.Rim.Model, @Model.WheelSetup.Rim.SizeInJ J @Model.WheelSetup.Rim.Material</td>
                </tr>
                <tr>
                    <th>Suspension</th>
                    <td>@Model.Suspension.Brand @Model.Suspension.Type</td>
                </tr>
                <tr>
                    <th>Ride Height</th>
                    <td>@Model.Suspension.RideHeightMm mm</td>
                </tr>
                <tr>
                    <th>Adjustable</th>
                    <td>
                        Height: @(Model.Suspension.IsHeightAdjustable ? "Yes" : "No"),
                        Stiffness: @(Model.Suspension.IsStiffnessAdjustable ? "Yes" : "No")
                    </td>
                </tr>
                <tr>
                    <th>Strut Bars</th>
                    <td>
                        Front: @(Model.Suspension.HasFrontStrutBar ? "Yes" : "No"),
                        Rear: @(Model.Suspension.HasRearStrutBar ? "Yes" : "No")
                    </td>
                </tr>
            </tbody>
        </table>

        <a class="car-details-back" asp-controller="Car" asp-action="Index">Back to cars</a>
    </div>
</section>
