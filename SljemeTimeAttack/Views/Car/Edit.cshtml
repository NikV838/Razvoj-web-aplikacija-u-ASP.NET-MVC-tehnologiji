@model SljemeTimeAttack.ViewModels.CarEditViewModel

@{
    ViewData["Title"] = $"Edit {Model.Make} {Model.Model}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/driver-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/car-pages.css" asp-append-version="true" />
}

<section class="car-index-page">
    <div class="car-list-section car-form-shell">
        <div class="car-page-header">
            <div>
                <p class="car-kicker">@Model.RegistrationNumber</p>
                <h1 class="car-list-title">Edit car</h1>
            </div>
            <a class="car-action car-action-secondary" asp-controller="Car" asp-action="Details" asp-route-id="@Model.Id">Back to car</a>
        </div>

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="car-form-card driver-form-card" data-driver-form novalidate>
            <input asp-for="Id" type="hidden" />
            @await Html.PartialAsync("_CarForm", Model)

            <div class="driver-form-actions">
                <button type="submit" class="car-action car-action-primary">Save changes</button>
                <a class="car-action car-action-secondary" asp-controller="Car" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
            </div>
        </form>
    </div>
</section>

<script src="~/js/timeattack-autocomplete.js" asp-append-version="true"></script>
<script src="~/js/timeattack-inline-parts.js" asp-append-version="true"></script>
<script src="~/js/car-image-upload.js" asp-append-version="true"></script>
@await Html.PartialAsync("~/Views/Driver/_DriverClientValidation.cshtml")
