@model IEnumerable<SljemeTimeAttack.Models.Run>

@{
    ViewData["Title"] = "Runs";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var canCreateRuns = isAuthenticated;
}

@section Styles {
    <link rel="stylesheet" href="~/css/run-pages.css" asp-append-version="true" />
}

<section class="run-index-bg">
    <div class="run-list-section">
        <div class="run-page-header">
            <div>
                <p class="run-kicker">Timing board</p>
                <h1 class="run-list-title">Time Attack Runs</h1>
            </div>
            @if (canCreateRuns)
            {
                <a class="run-back" asp-controller="Run" asp-action="Create">Add run</a>
            }
        </div>

        <div class="run-search-panel" data-run-search-panel>
            <label class="run-search-label" for="runSearch">Search runs</label>
            <div class="run-search-row">
                <input id="runSearch"
                       class="run-search-input"
                       type="search"
                       placeholder="Track, driver, car, registration, weather..."
                       autocomplete="off"
                       data-run-search
                       data-run-search-url="@Url.Action("Search", "Run")" />
                <span class="run-search-status" data-run-search-status aria-live="polite">@Model.Count() runs</span>
            </div>
        </div>

        <section class="run-direction-filters" aria-label="Filter runs by direction" data-run-direction-filters>
            <button class="run-direction-filter run-direction-filter--uphill"
                    type="button"
                    data-run-direction-filter="uphill"
                    aria-pressed="false">
                <span class="run-direction-filter__visual" aria-hidden="true">
                    <span class="run-direction-filter__road">
                        <svg class="run-direction-filter__car" viewBox="0 0 120 42" focusable="false">
                            <ellipse class="run-direction-filter__car-shadow" cx="60" cy="35" rx="42" ry="2.8" />
                            <g class="run-direction-filter__car-body">
                                <path class="run-direction-filter__car-shell" d="M9 29c8-8 19-12 34-13 7-5 15-8 25-8 13 0 25 7 34 18 5 1 8 3 10 6H8c-1 0-1-2 1-3Z" />
                                <path class="run-direction-filter__car-window" d="M45 15c6-3 13-5 22-5 9 0 17 4 24 12H33c3-3 7-6 12-7Z" />
                            </g>
                            <g class="run-direction-filter__wheel run-direction-filter__wheel--front">
                                <circle cx="86" cy="31" r="5.6" />
                                <circle class="run-direction-filter__wheel-center" cx="86" cy="31" r="1.7" />
                            </g>
                            <g class="run-direction-filter__wheel run-direction-filter__wheel--rear">
                                <circle cx="33" cy="31" r="5.6" />
                                <circle class="run-direction-filter__wheel-center" cx="33" cy="31" r="1.7" />
                            </g>
                        </svg>
                    </span>
                </span>
                <span class="run-direction-filter__content">
                    <span class="run-direction-filter__eyebrow">Mountain sector</span>
                    <span class="run-direction-filter__title">Uphill</span>
                </span>
            </button>
            <button class="run-direction-filter run-direction-filter--downhill"
                    type="button"
                    data-run-direction-filter="downhill"
                    aria-pressed="false">
                <span class="run-direction-filter__visual" aria-hidden="true">
                    <span class="run-direction-filter__road">
                        <svg class="run-direction-filter__car" viewBox="0 0 120 42" focusable="false">
                            <ellipse class="run-direction-filter__car-shadow" cx="60" cy="35" rx="42" ry="2.8" />
                            <g class="run-direction-filter__car-body">
                                <path class="run-direction-filter__car-shell" d="M9 29c8-8 19-12 34-13 7-5 15-8 25-8 13 0 25 7 34 18 5 1 8 3 10 6H8c-1 0-1-2 1-3Z" />
                                <path class="run-direction-filter__car-window" d="M45 15c6-3 13-5 22-5 9 0 17 4 24 12H33c3-3 7-6 12-7Z" />
                            </g>
                            <g class="run-direction-filter__wheel run-direction-filter__wheel--front">
                                <circle cx="86" cy="31" r="5.6" />
                                <circle class="run-direction-filter__wheel-center" cx="86" cy="31" r="1.7" />
                            </g>
                            <g class="run-direction-filter__wheel run-direction-filter__wheel--rear">
                                <circle cx="33" cy="31" r="5.6" />
                                <circle class="run-direction-filter__wheel-center" cx="33" cy="31" r="1.7" />
                            </g>
                        </svg>
                    </span>
                </span>
                <span class="run-direction-filter__content">
                    <span class="run-direction-filter__eyebrow">Descent pace</span>
                    <span class="run-direction-filter__title">Downhill</span>
                </span>
            </button>
        </section>

        <ul class="run-list" data-run-list>
            @foreach (var run in Model)
            {
                var canManageRun = User.IsInRole("Admin") || (isAuthenticated && run.Driver?.AppUserId == currentUserId);
                <li data-run-direction="@run.Direction.ToString().ToLowerInvariant()">
                    <a class="run-list-link" asp-controller="Run" asp-action="Details" asp-route-id="@run.Id">
                        <span class="run-main">
                            <span class="run-name">@run.Track</span>
                            <span class="run-meta">
                                Run @run.Id &bull; @(run.Driver?.Name ?? "Unknown driver") &bull; @(run.Car == null ? "Unknown car" : $"{run.Car.Make} {run.Car.Model}")
                            </span>
                        </span>
                        <span class="run-side">
                            <span class="run-besttime">@run.BestTime.ToString(@"m\:ss")</span>
                            <span class="run-track-badge">@run.Weather</span>
                        </span>
                    </a>
                    @if (canManageRun)
                    {
                        <div class="run-row-actions">
                            <a asp-controller="Run" asp-action="Edit" asp-route-id="@run.Id">Edit</a>
                            <a asp-controller="Run" asp-action="Delete" asp-route-id="@run.Id">Delete</a>
                        </div>
                    }
                </li>
            }
        </ul>

        <p class="run-empty" data-run-empty hidden>No runs match that search.</p>
    </div>
</section>

@section Scripts {
    <script src="~/js/run-index.js" asp-append-version="true"></script>
}
