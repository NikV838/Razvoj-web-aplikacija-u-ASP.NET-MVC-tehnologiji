@model IEnumerable<SljemeTimeAttack.Models.Run>

@{
    ViewData["Title"] = "Runs";
}

@section Styles {
    <link rel="stylesheet" href="~/css/run-pages.css" asp-append-version="true" />
}

<section class="run-index-bg">
    <div class="run-list-section">
        <div class="driver-page-header">
            <div>
                <p class="run-kicker">Timing board</p>
                <h1 class="run-list-title">Time Attack Runs</h1>
            </div>
            <a class="run-back" asp-controller="Run" asp-action="Create">Add run</a>
        </div>

        <ul class="run-list">
            @foreach (var run in Model)
            {
                <li>
                    <a class="run-list-link" asp-controller="Run" asp-action="Details" asp-route-id="@run.Id">
                        <span class="run-main">
                            <span class="run-name">@run.Track</span>
                            <span class="run-meta">
                                Run @run.Id &bull; @(run.Driver?.Name ?? "Unknown driver") &bull; @(run.Car == null ? "Unknown car" : $"{run.Car.Make} {run.Car.Model}")
                            </span>
                        </span>
                        <span class="run-side">
                            <span class="run-besttime">@run.BestTime.ToString(@"m\:ss")</span>
                            <span class="run-track-badge">@run.Weather</span>
                        </span>
                    </a>
                    <div class="driver-row-actions">
                        <a asp-controller="Run" asp-action="Edit" asp-route-id="@run.Id">Edit</a>
                    </div>
                </li>
            }
        </ul>
    </div>
</section>
