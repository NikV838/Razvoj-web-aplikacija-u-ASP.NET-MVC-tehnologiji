@model SljemeTimeAttack.Models.Run

@{
    ViewData["Title"] = $"Run {Model.Id}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/run-pages.css" asp-append-version="true" />
}

<section class="run-details-bg">
    <div class="run-details-shell">
        <article class="run-hero-card">
            <div class="run-page-header">
                <div>
                    <p class="run-kicker">Run @Model.Id</p>
                    <h1 class="run-details-title">@Model.Track</h1>
                </div>
                <div class="run-header-actions">
                    <a class="run-secondary-action" asp-controller="Run" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
                    <a class="run-danger-action" asp-controller="Run" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
                </div>
            </div>
            <div class="run-stat-grid">
                <div>
                    <dt>Best Time</dt>
                    <dd>@Model.BestTime.ToString(@"m\:ss")</dd>
                </div>
                <div>
                    <dt>Direction</dt>
                    <dd>@Model.Direction</dd>
                </div>
                <div>
                    <dt>Weather</dt>
                    <dd>@Model.Weather</dd>
                </div>
                <div>
                    <dt>Date</dt>
                    <dd>@Model.Date.ToString("dd.MM.yyyy.")</dd>
                </div>
            </div>
        </article>

        <section class="run-panel-grid">
            <a class="run-related-card" asp-controller="Driver" asp-action="Details" asp-route-id="@Model.DriverId">
                <span>Driver</span>
                <strong>@(Model.Driver?.Name ?? "Unknown driver")</strong>
                <em>@(Model.Driver?.Username ?? "N/A")</em>
            </a>

            <a class="run-related-card" asp-controller="Car" asp-action="Details" asp-route-id="@Model.CarId">
                <span>Car</span>
                <strong>@(Model.Car?.Make ?? "Unknown") @(Model.Car?.Model ?? "car")</strong>
                <em>@(Model.Car?.RegistrationNumber ?? "N/A")</em>
            </a>
        </section>

        <section class="run-files" data-run-files data-run-id="@Model.Id" data-can-edit="@(User.IsInRole("Admin") || User.IsInRole("User") || User.IsInRole("Racer") ? "true" : "false")">
            <div class="run-files__header">
                <h2>Files</h2>
            </div>

            @if (User.IsInRole("Admin") || User.IsInRole("User") || User.IsInRole("Racer"))
            {
                <form class="run-files__upload" data-run-file-upload>
                    @Html.AntiForgeryToken()
                    <input type="file" name="file" />
                    <button type="submit">Upload</button>
                </form>
            }

            <div class="run-files__status" data-run-files-status></div>
            <ul class="run-files__list" data-run-files-list></ul>
        </section>

        <a class="run-back" asp-controller="Run" asp-action="Index">Back to runs</a>
    </div>
</section>

@section Scripts {
    <script src="~/js/run-files.js" asp-append-version="true"></script>
}
