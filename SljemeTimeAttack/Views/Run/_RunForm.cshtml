@model SljemeTimeAttack.ViewModels.RunFormViewModel

<div asp-validation-summary="ModelOnly" class="run-validation-summary"></div>

<div class="run-form-grid">
    <div class="run-form-field">
        <label asp-for="Track" class="run-form-label"></label>
        <select asp-for="Track" asp-items="Model.TrackOptions" class="run-input">
            <option value="">Select track</option>
        </select>
        <span asp-validation-for="Track" class="run-validation-message"></span>
    </div>

    <div class="run-form-field">
        <label asp-for="BestTime" class="run-form-label">Best time</label>
        <input asp-for="BestTime" class="run-input" placeholder="5:20" />
        <span asp-validation-for="BestTime" class="run-validation-message"></span>
    </div>

    <div class="run-form-field run-form-field-wide">
        @await Html.PartialAsync("~/Views/Shared/_DateTimeControl.cshtml", new SljemeTimeAttack.ViewModels.DateTimeControlViewModel
        {
            FieldName = nameof(Model.Date),
            Label = "Session date and time",
            Value = Model.Date,
            Placeholder = "Select run date and start time"
        })
    </div>

    <div class="run-form-field">
        <label asp-for="Direction" class="run-form-label"></label>
        <select asp-for="Direction" asp-items="Model.DirectionOptions" class="run-input">
            <option value="">Select direction</option>
        </select>
        <span asp-validation-for="Direction" class="run-validation-message"></span>
    </div>

    <div class="run-form-field">
        <label asp-for="Weather" class="run-form-label"></label>
        <select asp-for="Weather" asp-items="Model.WeatherOptions" class="run-input">
            <option value="">Select weather</option>
        </select>
        <span asp-validation-for="Weather" class="run-validation-message"></span>
    </div>

    <div class="run-form-field">
        <label asp-for="DriverId" class="run-form-label">Driver</label>
        <select asp-for="DriverId" asp-items="Model.DriverOptions" class="run-input">
            <option value="">Select driver</option>
        </select>
        <span asp-validation-for="DriverId" class="run-validation-message"></span>
    </div>

    <div class="run-form-field">
        <label asp-for="CarId" class="run-form-label">Car</label>
        <select asp-for="CarId" asp-items="Model.CarOptions" class="run-input">
            <option value="">Select car</option>
        </select>
        <span asp-validation-for="CarId" class="run-validation-message"></span>
    </div>
</div>
