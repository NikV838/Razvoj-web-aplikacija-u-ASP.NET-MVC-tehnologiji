@model SljemeTimeAttack.Models.Run

@{
    ViewData["Title"] = $"Edit Run {Model.Id}";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/css/run-pages.css" asp-append-version="true" />
}

<section class="run-details-bg">
    <div class="run-details-shell run-form-shell">
        <div class="run-page-header">
            <div>
                <p class="run-kicker">Run @Model.Id</p>
                <h1 class="run-details-title">Edit run</h1>
            </div>
            <a class="run-secondary-action" asp-controller="Run" asp-action="Details" asp-route-id="@Model.Id">Back to run</a>
        </div>

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="run-form-card" data-run-form>
            <input asp-for="Id" type="hidden" />
            @await Html.PartialAsync("_RunForm", Model)

            <div class="run-form-actions">
                <button type="submit" class="run-back" data-loading-label="Saving changes">Save changes</button>
                <a class="run-secondary-action" asp-controller="Run" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        (() => {
            if (window.flatpickr) {
                flatpickr("[data-datetime-control]", {
                    enableTime: true,
                    dateFormat: "Y-m-d H:i",
                    altInput: true,
                    altFormat: "d.m.Y. H:i",
                    time_24hr: true
                });
            }

            document.querySelector("[data-run-form]")?.addEventListener("submit", event => {
                const form = event.currentTarget;
                form.classList.add("is-submitting");
                form.querySelectorAll("button[type='submit']").forEach(button => {
                    button.textContent = button.dataset.loadingLabel || "Saving";
                    button.disabled = true;
                });
            });
        })();
    </script>
}
