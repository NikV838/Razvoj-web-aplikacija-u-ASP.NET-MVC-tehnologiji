@model SljemeTimeAttack.ViewModels.RunCreateViewModel

@{
    ViewData["Title"] = "Create Run";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/css/driver-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/run-pages.css" asp-append-version="true" />
}

<section class="run-details-bg">
    <div class="run-details-shell run-form-shell">
        <div class="run-page-header">
            <div>
                <p class="run-kicker">Timing desk</p>
                <h1 class="run-details-title">Create run</h1>
            </div>
            <a class="run-secondary-action" asp-controller="Run" asp-action="Index">Back to runs</a>
        </div>

        <form asp-action="Create" method="post" class="run-form-card" data-driver-form novalidate>
            @await Html.PartialAsync("_RunForm", Model)

            <div class="run-form-actions">
                <button type="submit" class="run-back" data-loading-label="Saving run">Create run</button>
                <a class="run-secondary-action" asp-controller="Run" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/hr.js"></script>
    <script src="~/js/timeattack-datetime.js" asp-append-version="true"></script>
    @await Html.PartialAsync("~/Views/Driver/_DriverClientValidation.cshtml")
}
