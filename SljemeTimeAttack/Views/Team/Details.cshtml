@model SljemeTimeAttack.Models.Team

@{
    ViewData["Title"] = Model.Name;
}

@section Styles {
    <link rel="stylesheet" href="~/css/team-pages.css" asp-append-version="true" />
}

<section class="team-details-bg">
    <div class="team-details-shell">
        <article class="team-hero-card">
            <p class="team-kicker">Team Profile</p>
            <h1 class="team-details-title">@Model.Name</h1>

            <div class="team-stat-grid">
                <div>
                    <dt>Country</dt>
                    <dd>@Model.Country</dd>
                </div>
                <div>
                    <dt>Sponsor</dt>
                    <dd>@(Model.Sponsor ?? "Independent")</dd>
                </div>
                <div>
                    <dt>Drivers</dt>
                    <dd>@Model.Drivers.Count</dd>
                </div>
            </div>
        </article>

        <section class="team-panel">
            <h2>Drivers</h2>
            @if (Model.Drivers != null && Model.Drivers.Any())
            {
                <div class="team-driver-grid">
                    @foreach (var driver in Model.Drivers)
                    {
                        <a class="team-driver-card" asp-controller="Driver" asp-action="Details" asp-route-id="@driver.Id">
                            <strong>@driver.Name</strong>
                            <span>@driver.Username</span>
                            <em>@driver.YearsOfExperience years experience</em>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="team-empty">No drivers in this team.</p>
            }
        </section>

        <a class="team-back" asp-controller="Team" asp-action="Index">Back to teams</a>
    </div>
</section>
