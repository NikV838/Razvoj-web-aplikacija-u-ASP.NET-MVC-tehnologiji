@* Basic layout placeholder *@
@inject Microsoft.AspNetCore.Identity.UserManager<AppUser> UserManager
@{
    var currentUser = User.Identity?.IsAuthenticated == true
        ? await UserManager.GetUserAsync(User)
        : null;
    var currentUserName = currentUser?.UserName ?? User.Identity?.Name;
    var welcomeMessage = TempData["WelcomeMessage"] as string;
    var navSearchTerm = Context.Request.Query["q"].ToString();
}
<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"] - Sljeme Time Attack</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(string.IsNullOrWhiteSpace(welcomeMessage) ? null : "welcome-active")">
    <header>
        <nav class="site-nav" aria-label="Main navigation">
            <form asp-controller="Search" asp-action="Index" method="get" class="site-nav__search" role="search">
                <button type="button" class="site-nav__search-toggle" aria-label="Open global search">
                    <span aria-hidden="true"></span>
                </button>
                <input name="q"
                       value="@navSearchTerm"
                       type="search"
                       placeholder="Search cars, drivers, teams..."
                       aria-label="Global search"
                       autocomplete="off" />
            </form>
            <div class="site-nav__links">
                <a href="/">Home</a>
                <span aria-hidden="true">|</span>
                <a href="/Driver">Drivers</a>
                <span aria-hidden="true">|</span>
                <a href="/Car">Cars</a>
                <span aria-hidden="true">|</span>
                <a href="/Run">Runs</a>
                <span aria-hidden="true">|</span>
                <a href="/Team">Teams</a>
                @if (User.IsInRole("Admin"))
                {
                    <span aria-hidden="true">|</span>
                    <a asp-controller="Admin" asp-action="Users">Users</a>
                }
            </div>
            <div class="site-nav__auth">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Account" asp-action="Profile">My Garage</a>
                    <span aria-hidden="true">|</span>
                    <span class="site-nav__user" aria-label="Signed in user">@currentUserName</span>
                    <span aria-hidden="true">|</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="inline-form">
                        <button type="submit">Logout</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Index" class="site-nav__account">My Account</a>
                }
            </div>
        </nav>
    </header>
    @if (!string.IsNullOrWhiteSpace(welcomeMessage))
    {
        <div class="welcome-overlay" role="status" aria-live="polite">
            <div class="welcome-overlay__text">@welcomeMessage</div>
        </div>
    }
    <main role="main" class="container">
        @RenderBody()
    </main>
    <script>
        (() => {
            document.querySelectorAll(".site-nav__search").forEach(form => {
                const toggle = form.querySelector(".site-nav__search-toggle");
                const input = form.querySelector("input[type='search']");
                toggle?.addEventListener("click", () => input?.focus());
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
