@model SljemeTimeAttack.Models.Driver

@{
    ViewData["Title"] = Model.Name;
}

@section Styles {
    <link rel="stylesheet" href="~/css/driver-pages.css" asp-append-version="true" />
}

<section class="driver-details-bg">
    <div class="driver-details-shell">
        <article class="driver-profile-card">
            <div class="driver-page-header">
                <div>
                    <p class="driver-kicker">@Model.Username</p>
                    <h1 class="driver-details-title">@Model.Name</h1>
                </div>
                <div class="driver-header-actions">
                    <a class="driver-action driver-action-secondary" asp-controller="Driver" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
                    <a class="driver-action driver-action-danger" asp-controller="Driver" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
                </div>
            </div>

            <dl class="driver-stat-grid">
                <div>
                    <dt>Age</dt>
                    <dd>@Model.Age</dd>
                </div>
                <div>
                    <dt>Experience</dt>
                    <dd>@Model.YearsOfExperience years</dd>
                </div>
                <div>
                    <dt>Team</dt>
                    <dd>@(Model.Team?.Name ?? "Independent")</dd>
                </div>
                <div>
                    <dt>Country</dt>
                    <dd>@(Model.Team?.Country ?? "N/A")</dd>
                </div>
            </dl>

            <div class="driver-contact-row">
                <span>@(Model.Email ?? "No email listed")</span>
                <span>@(Model.PhoneNumber ?? "No phone listed")</span>
            </div>
        </article>

        <section class="driver-panel">
            <h2>Cars Owned</h2>
            @if (Model.CarsOwned != null && Model.CarsOwned.Any())
            {
                <div class="driver-card-grid">
                    @foreach (var car in Model.CarsOwned)
                    {
                        <a class="driver-car-card" asp-controller="Car" asp-action="Details" asp-route-id="@car.Id">
                            <strong>@car.Make @car.Model</strong>
                            <span>@car.Horsepower hp &bull; @car.WeightKg kg</span>
                            <em>@car.RegistrationNumber</em>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="driver-empty">No cars owned.</p>
            }
        </section>

        <section class="driver-panel">
            <h2>Runs</h2>
            @if (Model.Runs != null && Model.Runs.Any())
            {
                <div class="driver-run-list">
                    @foreach (var run in Model.Runs)
                    {
                        <div class="driver-run-row">
                            <strong>@run.Track</strong>
                            <span>@run.BestTime.ToString(@"m\:ss") &bull; @run.Direction &bull; @run.Weather</span>
                            <em>@run.Date.ToString("dd.MM.yyyy.")</em>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="driver-empty">No runs recorded.</p>
            }
        </section>

        <a class="driver-action driver-action-primary driver-back" asp-controller="Driver" asp-action="Index">Back to drivers</a>
    </div>
</section>
